<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>India Multibagger Universe — All 13 Sectors + Final Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#03050b;--s1:#080c16;--s2:#0c1120;--s3:#101628;
  --b1:#16223a;--b2:#1c2e4a;
  --nuc:#c084fc;--semi:#38bdf8;--def:#fb7185;--cap:#fb923c;--dc:#34d399;
  --re:#4ade80;--rail:#fbbf24;--spc:#e879f9;--ev:#f97316;--wat:#22d3ee;--hlt:#f43f5e;
  --pwr:#facc15;--ai:#a78bfa;
  --text:#dde6f5;--dim:#5a7896;--faint:#1a3050;
  --gold:#fbbf24;--white:#f0f6ff;
}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);padding:18px 14px 80px;}
.page{max-width:920px;margin:0 auto;}

/* HERO */
.hero{text-align:center;padding:28px 16px 24px;position:relative;margin-bottom:4px;}
.hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:400px;height:1px;background:linear-gradient(90deg,transparent,var(--ai),transparent);}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:var(--b1);}
.htitle{font-family:'Fraunces',serif;font-size:20px;font-weight:800;color:var(--white);margin-bottom:6px;}
.hsub{font-size:9px;font-family:'DM Mono',monospace;color:var(--dim);letter-spacing:.8px;line-height:2.2;}
.hpills{display:flex;flex-wrap:wrap;justify-content:center;gap:4px;margin-top:10px;}
.hp{font-size:8px;font-family:'DM Mono',monospace;padding:3px 9px;border-radius:14px;}

/* UNIVERSE SUMMARY */
.uni{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--b1);border:1px solid var(--b1);border-radius:10px;overflow:hidden;margin:14px 0 6px;}
.uc{background:var(--s1);padding:11px 8px;text-align:center;}
.uv{font-family:'Fraunces',serif;font-size:20px;font-weight:800;}
.ul{font-size:7.5px;font-family:'DM Mono',monospace;color:var(--dim);letter-spacing:.5px;margin-top:3px;}

/* NAV */
.nav-wrap{margin:12px 0 6px;}
.nr1{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--b1);border:1px solid var(--b1);border-top-left-radius:9px;border-top-right-radius:9px;overflow:hidden;}
.nr2{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:var(--b1);border:1px solid var(--b1);border-top:none;overflow:hidden;}
.nr3{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--b1);border:1px solid var(--b1);border-top:none;border-bottom-left-radius:9px;border-bottom-right-radius:9px;overflow:hidden;}
.nb{padding:8px 3px;text-align:center;font-size:8px;font-weight:600;font-family:'DM Mono',monospace;cursor:pointer;background:var(--s1);color:var(--dim);border:none;transition:all .15s;letter-spacing:.1px;line-height:1.3;}
.nb:hover{background:var(--s2);}
.nb.active{color:var(--white);}
.nb.final-btn{font-size:9px;font-weight:700;background:var(--s2);}

/* PANELS */
.panel{display:none;}.panel.active{display:block;}

/* SECTOR HERO */
.sh{border-radius:10px;padding:16px 20px 14px;margin-bottom:8px;border:1px solid;}
.si{font-size:22px;margin-bottom:5px;}
.sn{font-family:'Fraunces',serif;font-size:17px;font-weight:800;color:var(--white);margin-bottom:4px;}
.st{display:inline-block;font-size:7.5px;font-family:'DM Mono',monospace;padding:2px 9px;border-radius:8px;margin-bottom:5px;}
.sd{font-size:10px;color:rgba(255,255,255,.45);line-height:1.6;max-width:700px;}
.sr{display:flex;gap:16px;margin-top:10px;flex-wrap:wrap;}
.ss{text-align:left;}
.sv{font-family:'Fraunces',serif;font-size:14px;font-weight:700;color:var(--white);}
.sl{font-size:7.5px;font-family:'DM Mono',monospace;color:rgba(255,255,255,.3);margin-top:1px;letter-spacing:.4px;}

/* LAYER */
.ly{margin-bottom:7px;}
.lh{display:flex;align-items:center;gap:8px;padding:7px 12px;background:var(--s1);border:1px solid var(--b1);border-radius:8px 8px 0 0;border-bottom:none;}
.ln{font-family:'DM Mono',monospace;font-size:8px;padding:2px 6px;border-radius:4px;}
.lt{font-family:'Fraunces',serif;font-size:12px;font-weight:700;flex:1;}
.lc{font-size:8px;font-family:'DM Mono',monospace;color:var(--dim);}
.lb{border:1px solid var(--b1);border-radius:0 0 8px 8px;overflow:hidden;}

/* TABLE HEADER */
.th{display:grid;grid-template-columns:22px 1fr 80px 82px 62px;background:var(--s1);border-bottom:1px solid var(--b1);}
.th div{padding:5px 8px;font-size:7px;font-family:'DM Mono',monospace;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--dim);}
.th div:nth-child(3),.th div:nth-child(4),.th div:nth-child(5){text-align:center;}

/* COMPANY ROW */
.cr{display:grid;grid-template-columns:22px 1fr 80px 82px 62px;align-items:center;border-bottom:1px solid #090f1c;transition:background .12s;}
.cr:last-child{border-bottom:none;}
.cr:hover{background:var(--s2);}
.ci{text-align:center;padding:8px 4px;font-family:'DM Mono',monospace;font-size:9px;color:var(--faint);}
.cm{padding:8px 10px;}
.cn{font-weight:600;font-size:11.5px;color:var(--white);line-height:1.2;}
.cs{font-size:8px;color:var(--dim);font-family:'DM Mono',monospace;margin-top:1px;line-height:1.4;}
.cc{padding:8px 5px;text-align:center;}
.cp{display:inline-block;font-size:7px;font-family:'DM Mono',monospace;padding:2px 6px;border-radius:6px;}
.lc2{background:#60a5fa12;color:#60a5fa;border:1px solid #60a5fa28;}
.mc{background:#34d39912;color:#34d399;border:1px solid #34d39928;}
.sm{background:#fbbf2412;color:#fbbf24;border:1px solid #fbbf2428;}
.sc{background:#fb718512;color:#fb7185;border:1px solid #fb718528;}
.ul{background:#94a3b812;color:#94a3b8;border:1px solid #94a3b828;}
.pot{padding:8px 5px;text-align:center;font-size:10px;letter-spacing:-1.5px;}
.port{padding:8px 6px;text-align:center;}
.pt{display:inline-block;font-size:7px;font-family:'DM Mono',monospace;padding:2px 5px;border-radius:3px;}
.p1{background:#38bdf815;color:#38bdf8;border:1px solid #38bdf828;}
.p2{background:#34d39915;color:#34d399;border:1px solid #34d39928;}
.p3{background:#fbbf2415;color:#fbbf24;border:1px solid #fbbf2428;}
.pw{background:#5a789615;color:#5a7896;border:1px solid #5a789628;}
.pv{background:#fb718515;color:#fb7185;border:1px solid #fb718528;}

/* FINAL PORTFOLIO CARDS */
.final-grid{display:flex;flex-direction:column;gap:7px;margin-bottom:6px;}
.fc{border-radius:10px;border:1px solid var(--b1);overflow:hidden;}
.fch{display:flex;align-items:center;gap:11px;padding:11px 14px;background:var(--s1);border-bottom:1px solid var(--b1);}
.fc-num{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:14px;font-weight:700;flex-shrink:0;}
.fc-info{flex:1;min-width:0;}
.fc-name{font-weight:600;font-size:13px;color:var(--white);line-height:1.2;}
.fc-role{font-size:8.5px;color:var(--dim);font-family:'DM Mono',monospace;margin-top:2px;}
.fc-right{text-align:right;flex-shrink:0;}
.fc-pct{font-family:'Fraunces',serif;font-size:18px;font-weight:700;line-height:1;}
.fc-amt{font-size:8.5px;color:var(--dim);font-family:'DM Mono',monospace;margin-top:2px;}
.fcb{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;padding:11px 14px;background:var(--bg);}
.kl{font-size:7.5px;font-family:'DM Mono',monospace;color:var(--dim);letter-spacing:.5px;text-transform:uppercase;margin-bottom:3px;}
.kv{font-size:10.5px;color:var(--text);line-height:1.5;}
.badges{display:flex;flex-wrap:wrap;gap:3px;margin-top:2px;}
.sb{font-size:7px;font-family:'DM Mono',monospace;padding:1px 5px;border-radius:3px;white-space:nowrap;}
.s-nuc{background:#c084fc12;color:#c084fc;border:1px solid #c084fc25;}
.s-semi{background:#38bdf812;color:#38bdf8;border:1px solid #38bdf825;}
.s-def{background:#fb718512;color:#fb7185;border:1px solid #fb718525;}
.s-cap{background:#fb923c12;color:#fb923c;border:1px solid #fb923c25;}
.s-dc{background:#34d39912;color:#34d399;border:1px solid #34d39925;}
.s-re{background:#4ade8012;color:#4ade80;border:1px solid #4ade8025;}
.s-rail{background:#fbbf2412;color:#fbbf24;border:1px solid #fbbf2425;}
.s-spc{background:#e879f912;color:#e879f9;border:1px solid #e879f925;}
.s-ev{background:#f9731612;color:#f97316;border:1px solid #f9731625;}
.s-wat{background:#22d3ee12;color:#22d3ee;border:1px solid #22d3ee25;}
.s-hlt{background:#f43f5e12;color:#f43f5e;border:1px solid #f43f5e25;}
.s-pwr{background:#facc1512;color:#facc15;border:1px solid #facc1525;}
.s-ai{background:#a78bfa12;color:#a78bfa;border:1px solid #a78bfa25;}
.abar{height:3px;border-radius:2px;margin-top:8px;}

/* ALLOC SUMMARY TABLE */
.at{border:1px solid var(--b1);border-radius:10px;overflow:hidden;margin-bottom:7px;}
.at table{width:100%;border-collapse:collapse;}
.at thead th{background:var(--s1);padding:8px 12px;font-size:7px;text-transform:uppercase;letter-spacing:.8px;color:var(--dim);font-family:'DM Mono',monospace;border-bottom:1px solid var(--b1);text-align:left;white-space:nowrap;}
.at thead th.c{text-align:center;}
.at tbody td{padding:9px 12px;border-bottom:1px solid #090f1c;font-size:11.5px;vertical-align:middle;}
.at tbody tr:last-child td{border-bottom:none;}
.at tbody tr:hover td{background:var(--s2);}
.at td.c{text-align:center;font-family:'DM Mono',monospace;font-size:11px;}
.at td.amt{text-align:right;font-family:'Fraunces',serif;font-size:14px;font-weight:700;}
.tot-row td{background:var(--s2);font-weight:700;border-top:1px solid var(--b2)!important;}

/* DISC */
.disc{margin-top:18px;padding:11px 14px;border:1px solid var(--faint);border-radius:9px;background:#020407;}
.disc p{font-size:8px;color:#1a3050;font-family:'DM Mono',monospace;line-height:2;text-align:center;}

.note{background:var(--s2);border:1px solid var(--b2);border-radius:8px;padding:10px 14px;font-size:10.5px;color:#5a7896;line-height:1.7;margin:6px 0;}
.note strong{color:#38bdf8;}

.sec-divider{height:1px;background:var(--b1);margin:8px 0;}

@media(max-width:600px){
  .nr1{grid-template-columns:repeat(4,1fr);}
  .nr2{grid-template-columns:repeat(4,1fr);}
  .cr{grid-template-columns:20px 1fr 70px 70px;}
  .port{display:none;}.th div:last-child{display:none;}
  .fcb{grid-template-columns:1fr 1fr;}
  .uni{grid-template-columns:1fr 1fr 1fr;}
}
</style>
</head>
